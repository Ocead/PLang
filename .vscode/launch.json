{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current file",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Debug ANTLR4 grammar",
            "type": "antlr-debug",
            "request": "launch",
            "grammar": "lang/plang.g4",
            "input": "test/corpus/valid.plang",
            "actionFile": "test/action.js",
            "startRule": "start",
            "printParseTree": true,
            "visualParseTree": true
        }
    ]
}
